            "items": [
                {
                    "question_id": "1",
                    "order": 1,
                    "direction": 1,
                    "text": "I feel down-hearted and blue."
                },
                {
                    "question_id": "2",
                    "order": 2,
                    "direction": -1,
                    "text": "Morning is when I feel the best."
                },
                {
                    "question_id": "3",
                    "order": 3,
                    "direction": 1,
                    "text": "I have crying spells or feel like it."
                },
                {
                    "question_id": "4",
                    "order": 4,
                    "direction": 1,
                    "text": "I have trouble sleeping at night."
                },
                {
                    "question_id": "5",
                    "order": 5,
                    "direction": -1,
                    "text": "I eat as much as I used to."
                },
                {
                    "question_id": "6",
                    "order": 6,
                    "direction": -1,
                    "text": "I still enjoy sex."
                },
                {
                    "question_id": "7",
                    "order": 7,
                    "direction": 1,
                    "text": "I notice that I am losing weight."
                },
                {
                    "question_id": "8",
                    "order": 8,
                    "direction": 1,
                    "text": "I have trouble with constipation."
                },
                {
                    "question_id": "9",
                    "order": 9,
                    "direction": 1,
                    "text": "My heart beats faster than usual."
                },
                {
                    "question_id": "10",
                    "order": 10,
                    "direction": 1,
                    "text": "I get tired for no reason."
                },
                {
                    "question_id": "11",
                    "order": 11,
                    "direction": -1,
                    "text": "My mind is as clear as it used to be."
                },
                {
                    "question_id": "12",
                    "order": 12,
                    "direction": -1,
                    "text": "I find it easy to do the things I used to."
                },
                {
                    "question_id": "13",
                    "order": 13,
                    "direction": 1,
                    "text": "I am restless and can't keep still."
                },
                {
                    "question_id": "14",
                    "order": 14,
                    "direction": -1,
                    "text": "I feel hopeful about the future."
                },
                {
                    "question_id": "15",
                    "order": 15,
                    "direction": 1,
                    "text": "I am more irritable than usual."
                },
                {
                    "question_id": "16",
                    "order": 16,
                    "direction": -1,
                    "text": "I find it easy to make decisions."
                },
                {
                    "question_id": "17",
                    "order": 17,
                    "direction": -1,
                    "text": "I feel that I am useful and needed."
                },
                {
                    "question_id": "18",
                    "order": 18,
                    "direction": -1,
                    "text": "My life is pretty full."
                },
                {
                    "question_id": "19",
                    "order": 19,
                    "direction": 1,
                    "text": "I feel that others would be better off if I were dead."
                },
                {
                    "question_id": "20",
                    "order": 20,
                    "direction": -1,
                    "text": "I still enjoy the things I used to do."
                }
