{
  "version": "seo-agent-article-cms-publish-canary.v1",
  "task": "SEO-AGENT-ARTICLE-CMS-PUBLISH-CANARY-01",
  "repo": "fap-api",
  "command": "php artisan seo-agent:article-cms-publish-canary",
  "input_schemas": [
    "seo-agent-cms-draft-package-dry-run.v1",
    "seo-agent-controlled-cms-draft-write.v1",
    "seo-agent-gsc-draft-publish-gate-readiness.v1"
  ],
  "output_schema": "seo-agent-article-cms-publish-canary.v1",
  "default_mode": "dry_run_plan",
  "execute_requires": [
    "--execute",
    "--limit=1",
    "--target=article:<id>:<locale>",
    "--revision-id=<seo-agent-article-revision-id>",
    "--confirm-write-evidence-sha256=<write-evidence-sha256>",
    "--confirm-publish=<exact publish gate phrase>"
  ],
  "max_rows_per_execution": 1,
  "supported_targets_v1": [
    "article"
  ],
  "unsupported_targets_v1": [
    "content_page",
    "career_job",
    "personality_profile",
    "test_page"
  ],
  "publish_model": {
    "source_draft_table": "article_revisions",
    "runtime_publish_table": "article_translation_revisions",
    "behavior": "creates one approved article_translation_revision from the SEO Agent article draft, locks it as the article working revision, then promotes it through ArticlePublishService",
    "requires_publish_gate_status": "publish_ready",
    "preflight_blocks_runtime_seo_meta_length_overflow": true,
    "requires_write_evidence_sha256_confirmation": true,
    "requires_exact_human_confirmation": true
  },
  "runtime_field_length_preflight": {
    "article_seo_meta.seo_title": 60,
    "article_seo_meta.seo_description": 160,
    "article_seo_meta.og_title": 90,
    "article_seo_meta.og_description": 200,
    "blocked_issue": "seo_meta_field_length_exceeded"
  },
  "post_publish_boundaries": {
    "url_truth_write": false,
    "sitemap_submission": false,
    "indexnow_submit": false,
    "search_channel_enqueue": false,
    "search_channel_submit": false,
    "indexing_request": false,
    "scheduler_activation": false,
    "queue_worker_start": false,
    "external_model_api_call": false,
    "live_gsc_api_call": false
  },
  "evidence": {
    "records_package_sha256": true,
    "records_write_evidence_sha256": true,
    "records_publish_gate_evidence_sha256": true,
    "records_source_article_revision_id": true,
    "records_article_translation_revision_id": true,
    "records_rollback_snapshot_hashes": true,
    "forbidden_fields_absent": [
      "raw_url",
      "raw_query",
      "credential_path",
      "service_account_json",
      "client_email",
      "private_key",
      "Bearer token",
      "cookie",
      "content_md",
      "content_html",
      "cms_draft_body"
    ]
  },
  "next_step": "After one successful article publish canary, run read-only public runtime QA before any URL Truth, sitemap, IndexNow, or search submission approval."
}
