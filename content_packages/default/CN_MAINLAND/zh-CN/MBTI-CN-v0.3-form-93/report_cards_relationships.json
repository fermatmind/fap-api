          "side": "E",
          "min_delta": 12
        }
      },
      "access_level": "paid",
      "module_code": "relationships"
    },
    {
      "id": "rel_axis_EI_I_strong",
      "section": "relationships",
      "title": "I 偏好较强：通过深度与稳定建立关系信任",
      "desc": "你更偏好低噪音、高质量的连接方式，关系通常在长期理解与稳定陪伴中慢慢变深。",
      "bullets": [
        "你不靠高频互动维持关系",
        "你更看重被真正理解的感觉",
        "深度交流比表层热闹更能打动你"
      ],
      "tips": [
        "把真实想法说出来，不要只停在心里",
        "给重要关系一个固定的深聊窗口"
      ],
      "tags": [
        "kind:axis",
        "axis:EI:I",
        "state:strong",
        "topic:boundary"
      ],
