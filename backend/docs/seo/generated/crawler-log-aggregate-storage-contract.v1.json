    "user_agent_hash",
    "path_display_masked",
    "metadata_json"
  ],
  "no_migration_in_this_pr": true,
  "no_production_log_read": true,
  "no_canary_execution": true,
  "no_database_write": true,
  "no_scheduler": true,
  "no_issue_queue_write": true,
  "no_url_truth_mutation": true,
  "no_search_channel_queue_enqueue": true,
  "no_search_submission": true,
  "no_external_search_api": true,
  "required_fields": [
    "id",
    "log_date",
    "host",
    "surface_family",
    "bot_family",
    "bot_variant",
    "bot_verification_state",
    "route_family",
    "page_entity_type",
    "canonical_path",
    "path_hash",
    "http_status",
    "method_bucket",
    "query_present",
    "query_risk_state",
    "private_path_blocked",
    "hit_count",
    "first_seen_at",
    "last_seen_at",
    "source_log_family",
    "privacy_transform_version",
    "idempotency_key",
    "created_at",
    "updated_at"
  ],
  "required_indexes": [
    "unique_idempotency_key",
    "log_date",
    "host",
    "surface_family",
    "bot_family",
    "route_family",
    "http_status",
    "query_risk_state",
    "private_path_blocked",
    "log_date_host_bot_family",
    "log_date_surface_family_route_family"
  ],
  "idempotency_dimensions": [
    "log_date",
    "host",
    "surface_family",
    "bot_family",
    "bot_variant",
    "bot_verification_state",
    "route_family",
    "page_entity_type",
    "canonical_path",
    "path_hash",
    "http_status",
    "method_bucket",
    "query_present",
    "query_risk_state",
    "private_path_blocked",
    "source_log_family",
    "privacy_transform_version"
  ],
  "write_gate_env": "SEO_INTEL_CRAWLER_LOG_AGGREGATE_WRITE_ENABLED",
