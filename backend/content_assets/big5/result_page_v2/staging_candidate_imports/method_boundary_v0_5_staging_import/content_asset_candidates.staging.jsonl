{"asset_id":"candidate_content_method_boundary_v0_5_07","asset_key":"candidate.method_boundary.norm_unavailable_still_useful.v0_5","asset_version":"v0_5","asset_type":"norms_explanation","asset_layer":"L0_governance","module_key":"module_10_method_privacy","section_key":"method_privacy","slot_key":"module_10_method_privacy.method.norm_method","copy_role":"user_visible_method_boundary_candidate","reading_mode":["standard","deep"],"title_zh":"没有可靠参照，仍然可以读结构","body_zh":"没有可靠参照，并不等于结果失效。它只是说明：这次不适合用比较语言来说明你处在别人中的什么位置。报告仍然可以描述五个维度之间的高低关系、哪些细分面向更值得观察、哪些场景容易触发稳定模式。少了比较感，反而能让你更专注于“我如何运作”，而不是“我排在哪里”。\n\n边界：参照不可用时，应隐藏或弱化比较式表达；不应说你高于、低于或优于某类人群。","short_body_zh":"参照不可用时，报告不适合做群体比较，但仍可帮助你理解自己的倾向组合。","cta_zh":"把注意力放回三个问题：我更常怎样行动？在哪些场景反复出现？下一步能做什么小调整？","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["method_registry"],"target_module":["module_10_method_privacy"],"selection_scope":["norm_unavailable_boundary"],"candidate_replaces":["asset.module_10_method_privacy.method_registry.norm_method.v0_3"],"original_reading_modes":["standard","deep"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["method_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_10_method_privacy.method.norm_method","selection_priority":88,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":250,"sentence_count":5,"has_trait_layer":true,"has_score_band_layer":false,"has_coupling_layer":false,"has_facet_layer":true,"has_real_world_layer":true,"has_cost_layer":false,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":false,"template_risk":"v0_5_human_review_candidate","rendered_preview_re