    "max_lines_lte": 1000,
    "single_log_source": true,
    "single_short_time_window": true,
    "no_raw_persistence": true,
    "no_scheduler": true,
    "no_issue_queue_write": true,
    "no_search_submission": true,
    "no_metabase_mutation": true
