          "side": "J",
          "min_delta": 12
        }
      },
      "access_level": "paid",
      "module_code": "relationships"
    },
    {
      "id": "rel_axis_JP_P_strong",
      "section": "relationships",
      "title": "P 偏好较强：通过自发性和开放空间维持关系活力",
      "desc": "你更喜欢关系里保有呼吸感和新鲜度，太硬的规则会削弱你的自在和投入。",
      "bullets": [
        "弹性空间会让你更愿意靠近",
        "你很在意关系里的真实流动感",
        "临场交流通常比预设流程更自然"
      ],
      "tips": [
        "自由和回应都重要，别只保留前者",
        "把“之后再说”变成一个明确时间点"
      ],
      "tags": [
        "kind:axis",
        "axis:JP:P",
        "state:strong",
        "topic:freedom"
      ],
      "priority": 93,
      "match": {
