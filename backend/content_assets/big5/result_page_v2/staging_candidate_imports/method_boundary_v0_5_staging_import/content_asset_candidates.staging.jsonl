{"asset_id":"candidate_content_method_boundary_v0_5_04","asset_key":"candidate.method_boundary.thirty_facets_inference.v0_5","asset_version":"v0_5","asset_type":"method_boundary","asset_layer":"L0_governance","module_key":"module_10_method_privacy","section_key":"method_privacy","slot_key":"module_10_method_privacy.method.facet_method","copy_role":"user_visible_method_boundary_candidate","reading_mode":["standard","deep"],"title_zh":"细分面向用于解释，不用于定论","body_zh":"五个大维度下面各有更细的面向。它们能解释为什么同样是一个维度，有人表现为条理清楚，有人表现为责任感强，也有人主要体现在行动持续性上。细分面向的价值，是把一个宽泛维度拆开看；它的边界，是不能脱离整体结构单独下结论。一个细分面向击中你，说明它值得观察，不说明它已经证明了什么。\n\n边界：细分面向不能单独作为临床判断、能力判断或关系结论，也不能覆盖完整结果。","short_body_zh":"30 个细分面向能说明五个大维度内部的差异，但它们仍然是解释线索。","cta_zh":"遇到有共鸣的细分解释，写下一个真实场景；没有共鸣的部分，先放进“待观察”，不必强行接受。","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["method_registry"],"target_module":["module_10_method_privacy"],"selection_scope":["facet_inference_boundary"],"candidate_replaces":["asset.module_10_method_privacy.method_registry.facet_method.v0_3"],"original_reading_modes":["standard","deep"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["method_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_10_method_privacy.method.facet_method","selection_priority":91,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":262,"sentence_count":5,"has_trait_layer":true,"has_score_band_layer":false,"has_coupling_layer":false,"has_facet_layer":true,"has_real_world_layer":true,"has_cost_layer":false,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":false,"template_risk":"v0_5_human_review_candidate","rendered_preview_required":true},"safety_tags":["method_boundary","human_reviewed_candidate","staging_only","not_runtime","no_frontend_copy","no_production_use"],"qa_status":"safety_reviewed","ready_for_pilot":false,"runtime_use":"staging_only","production_use_allowed":false,"source_trace":{"source_pack":"big5_method_boundary_candidates_v0_5.zip","source_zip_sha256":"f69a85caba09654d9774d396a1bf785e2d6f0a26c652026f858422553aebd461","source_role":"citation_only","derived_from":["GPT v0.5 method/boundary candidate workpack","existing_big5_result_page_v2_asset_packs"],"candidate_replaces":["asset.module_10_method_privacy.method_registry.facet_method.v0_3"],"forbidden_copy_sources_excluded":true,"bfi_2_copy_used":false,"competitor_copy_used":false,"runtime_use":"staging_only","production_use_allowed":false},"repair_log_refs":[]}
{"asset_id":"candidate_content_method_boundary_v0_5_05","asset_key":"candidate.method_boundary.facet_domain_mismatch_reading.v0_5","asset_version":"v0_5","asset_type":"method_boundary","asset_layer":"L0_governance","module_key":"module_10_method_privacy","section_key":"method_privacy","slot_key":"module_10_method_privacy.method.facet_method","copy_role":"user_visible_method_boundary_candidate","reading_mode":["standard","deep"],"title_zh":"维度和细分面向可以不完全一致","body_zh":"人格特质不是整齐的方块。一个人在尽责性上可能整体偏稳定，但条理、责任感、目标推进、持续性和谨慎决策并不一定同时突出。大维度像总览图，细分面向像局部放大。两者不一致时，最合理的读法是：先保留大维度的方向，再用细分面向寻找具体场景里的差异。\n\n边界：不要用单个细分面向推翻整个结果，也不要用总维度掩盖局部差异。","short_body_zh":"一个大维度给出总结构，细分面向说明内部差异；两者不一致时，不必急着判定矛盾。","cta_zh":"把不一致的地方当成提问：它是在工作里出现，还是在关系、压力或自我管理中出现？","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["method_registry"],"target_module":["module_10_method_privacy"],"selection_scope":["facet_domain_mismatch_reading"],"candidate_replaces":["asset.module_10_method_privacy.method_registry.facet_method.v0_3"],"original_reading_modes":["standard","deep"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["method_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_10_method_privacy.method.facet_method","selection_priority":90,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":238,"sentence_count":5,"has_trait_layer":true,"has_score_band_layer":false,"has_coupling_layer":false,"has_facet_layer":true,"has_real_world_layer":true,"has_cost_layer":false,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":false,"template_risk":"v0_5_human_review_candidate","rendered_preview_required"