{
  "schema_version": "crawler-log-ops-observation-read-model.v1",
  "task": "CRAWLER-LOG-09",
  "runtime": "ops_seo_crawler_observation_read_model",
  "purpose": "Expose aggregate-only crawler observation data to the native /ops/seo dashboard read layer.",
  "service": "App\\Services\\SeoIntel\\OpsDashboard\\SeoCrawlerLogObservationReadService",
  "allowed_tables": [
    "seo_crawler_log_daily_aggregates"
  ],
  "forbidden_tables": [
    "seo_crawler_logs_daily",
    "seo_urls",
    "seo_issue_queue",
    "seo_search_channel_queue_items",
    "orders",
    "payment_events",
    "users",
    "reports",
    "attempts"
  ],
  "aggregate_dimensions": [
    "bot_family",
    "surface_family",
    "route_family",
    "http_status",
    "query_risk_state",
    "private_path_blocked"
  ],
  "safety_counts": [
    "private_path_blocked_count",
    "sensitive_query_count",
    "api_or_ops_surface_count",
    "unknown_bot_count"
  ],
  "safe_recent_row_fields": [
    "log_date",
    "host",
    "surface_family",
    "bot_family",
    "bot_variant",
    "bot_verification_state",
    "route_family",
    "page_entity_type",
    "canonical_path",
    "http_status",
    "method_bucket",
    "query_present",
    "query_risk_state",
    "private_path_blocked",
    "hit_count",
    "first_seen_at",
    "last_seen_at",
    "source_log_family",
    "privacy_transform_version",
    "updated_at"
  ],
  "forbidden_display_fields": [
    "path_hash",
    "idempotency_key",
    "ip_address",
    "remote_addr",
    "raw_user_agent",
    "raw_request_uri",
    "raw_query_string",
    "cookie",
    "headers",
    "authorization",
    "token",
    "api_key",
    "email",
    "order_no",
    "attempt_id",
    "payment_id",
    "provider_event_id",
    "raw_payload",
    "raw_log_line",
    "event_payload",
    "metadata_json",
    "attributes_json"
  ],
  "no_raw_log_read": true,
  "no_raw_persistence": true,
  "no_writes": true,
  "no_issue_queue_write": true,
  "no_url_truth_write": true,
  "no_search_channel_enqueue": true,
  "no_search_submission": true,
  "no_scheduler": true,
  "no_metabase_exposure": true,
  "next_task": "CRAWLER-LOG-10"
}
