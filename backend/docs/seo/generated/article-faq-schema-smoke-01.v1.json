    },
    {
      "schema_type": "FAQPage",
      "required_when": "visible_article_faq_exists",
      "source_authority": "answer_surface_v1.faq_blocks_or_approved_cms_backend_visible_faq",
      "expectation": "mainEntity count equals visible FAQ count"
