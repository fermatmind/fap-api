{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "npm run build:app && npm run build:ops-theme",
        "build:app": "vite build",
        "build:ops-theme": "node ./node_modules/tailwindcss-3/lib/cli.js --input ./resources/css/filament/ops/theme.css --output ./resources/css/filament/ops/theme.compiled.css --config ./resources/css/filament/ops/tailwind.config.js --minify",
        "dev": "vite"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.16",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "tailwindcss-3": "npm:tailwindcss@^3.4.19",
        "vite": "^7.0.7"
    }
}
