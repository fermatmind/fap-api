  "field_definitions": {
    "asset_id": {
      "type": "string",
      "description": "Globally unique content asset id."
    },
    "asset_key": {
      "type": "string",
      "description": "Human-readable stable key for selector and QA."
    },
    "asset_version": {
      "type": "string",
      "description": "Asset-level version, for example v0_1."
    },
    "asset_type": {
      "type": "enum",
      "description": "Type of content asset."
    },
    "asset_layer": {
      "type": "enum",
      "description": "Factory layer, for example L1_core_body or L5_facet_precision."
    },
    "module_key": {
      "type": "enum",
      "description": "V2 module key, module_00 through module_10."
    },
    "section_key": {
      "type": "enum",
      "description": "Big Five 8-section skeleton key."
    },
    "slot_key": {
      "type": "string",
      "description": "Slot inside module/section."
    },
    "copy_role": {
      "type": "enum",
      "description": "Role of the copy, e.g. user_visible_body, title, boundary, schema_example."
    },
    "reading_mode": {
      "type": "array<string>",
      "allowed": [
        "quick",
        "standard",
        "deep"
      ]
    },
    "title_zh": {
      "type": "string|null",
      "description": "User-visible Chinese title when applicable."
    },
    "body_zh": {
      "type": "string|null",
      "description": "User-visible body. Schema examples must not be production copy."
    },
    "short_body_zh": {
      "type": "string|null",
      "description": "Short card or quick-read body."
    },
    "cta_zh": {
      "type": "string|null",
      "description": "User-visible CTA label when applicable."
    },
    "applies_to": {
      "type": "object",
      "description": "Selector conditions."
    },
    "avoid_when": {
      "type": "array<object>",
      "description": "Suppression / downgrade rules."
    },
    "can_combine_with": {
      "type": "array<string>",
      "description": "Positive composition tags."
    },
    "cannot_combine_with": {
      "type": "array<string>",
      "description": "Conflict / dedupe tags."
    },
    "dedupe_group": {
      "type": "string",
      "description": "Only one item from same group unless explicitly allowed."
    },
    "selection_priority": {
      "type": "number",
      "description": "Base selection priority."
    },
    "selection_specificity": {
      "type": "number",
      "description": "Match specificity score."
    },
    "fallback_allowed": {
      "type": "boolean",
      "default": false
    },
    "render_surface": {
      "type": "array<string>",
      "description": "Allowed surfaces. Schema examples must use [] and not runtime surfaces."
    },
    "body_quality": {
      "type": "object",
      "description": "Author-side quality metadata, not final QA."
    },
    "safety_tags": {
      "type": "array<string>",
      "description": "Safety and boundary tags."
    },
    "qa_status": {
      "type": "enum",
      "allowed": [
        "draft",
        "source_mapped",
        "editorial_reviewed",
        "safety_reviewed",
        "mapping_qa_passed",
        "render_preview_passed",
        "ready_for_pilot",
        "blocked",
        "deprecated"
      ]
    },
    "ready_for_pilot": {
      "type": "boolean",
      "description": "Hard gate, see ready_for_pilot template."
    },
    "runtime_use": {
      "type": "enum",
      "allowed": [
        "not_runtime",
        "staging_only",
        "pilot_only",
        "runtime_allowed"
      ]
    },
    "production_use_allowed": {
      "type": "boolean",
      "default": false
    },
    "source_trace": {
      "type": "object",
      "description": "Source document, batch and reviewer trace."
    }
