{"asset_id":"candidate_content_method_boundary_v0_5_09","asset_key":"candidate.method_boundary.surface_privacy_matrix.v0_5","asset_version":"v0_5","asset_type":"privacy_boundary","asset_layer":"L0_governance","module_key":"module_10_method_privacy","section_key":"method_privacy","slot_key":"module_10_method_privacy.boundary.sensitive_content_boundary","copy_role":"user_visible_method_boundary_candidate","reading_mode":["standard","deep"],"title_zh":"不同场景，不同暴露边界","body_zh":"同一份结果在不同场景里不应展示同样多的信息。结果页可以承载较完整的解释；PDF 要注意保存和转发风险；分享卡应只保留可公开讨论的偏好和行动方向；历史记录应帮助用户回看变化，而不是暴露敏感细节；对比视图应避免把差异读成排序。隐私设计的重点不是少说，而是只在合适场景说合适的内容。\n\n边界：公开或半公开场景不能展示私密访问线索、答题细节、未处理计分信息或内部系统字段。","short_body_zh":"完整页面适合自读；PDF 适合保存；分享、历史和对比只应保留安全摘要和必要信息。","cta_zh":"准备分享前，优先选择短摘要；涉及压力、关系或恢复的内容，默认只供本人阅读。","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["boundary_registry"],"target_module":["module_10_method_privacy"],"selection_scope":["surface_privacy_boundary"],"candidate_replaces":["asset.module_10_method_privacy.boundary_registry.sensitive_content_boundary.v0_3","asset.module_10_method_privacy.method_registry.privacy_method.v0_3"],"original_reading_modes":["standard","deep"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["boundary_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_10_method_privacy.boundary.sensitive_content_boundary","selection_priority":86,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":265,"sentence_count":4,"has_trait_layer":false,"has_score_band_layer":false,"has_coupling_layer":false,"has_facet_layer":false,"has_real_world_layer":true,"has_cost_layer":true,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":false,"template_risk":"v0_5_human_review_candidate","rendered_preview_required":true},"safety_tags":["method_boundary","human_reviewed_candidate","staging_only","not_runtime","no_frontend_copy","no_production_use"],"qa_status":"safety_reviewed","ready_for_pilot":false,"runtime_use":"staging_only","production_use_allowed":false,"source_trace":{"source_pack":"big5_method_boundary_candidates_v0_5.zip","source_zip_sha256":"f69a85caba09654d9774d396a1bf785e2d6f0a26c652026f858422553aebd461","source_role":"citation_only","derived_from":["GPT v0.5 method/boundary candidate workpack","existing_big5_result_page_v2_asset_packs"],"candidate_replaces":["asset.module_10_method_privacy.boundary_registry.sensitive_content_boundary.v0_3","asset.module_10_method_privacy.method_registry.privacy_method.v0_3"],"forbidden_copy_sources_excluded":true,"bfi_2_copy_used":false,"competitor_copy_used":false,"runtime_use":"staging_only","production_use_allowed":false},"repair_log_refs":[]}
{"asset_id":"candidate_content_method_boundary_v0_5_10","asset_key":"candidate.method_boundary.share_safe_boundary.v0_5","asset_version":"v0_5","asset_type":"share_safe","asset_layer":"L0_governance","module_key":"module_08_share_save","section_key":"share_save","slot_key":"module_08_share_save.boundary.share_boundary","copy_role":"user_visible_method_boundary_candidate","reading_mode":["quick","standard"],"title_zh":"分享只保留可公开讨论的部分","body_zh":"一份人格报告里有些内容适合公开讨论，例如“我更需要清晰反馈”“我适合低噪音深度工作”“我正在练习提前说明边界”。也有些内容不适合离开原报告语境，例如压力恢复、关系摩擦、作答质量、参照条件和细分推断。分享版本应该像一张沟通卡，而不是完整报告的截图。\n\n边界：分享内容不应包含未处理计分信息、参照比较、私密线索、敏感压力描述或内部字段。","short_body_zh":"适合分享的是沟通偏好、协作提醒和下一步行动，不是完整私密解释。","cta_zh":"如果要分享，用一句“我正在尝试怎样协作”来表达，而不是分享整段私密解释。","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["boundary_registry"],"target_module":["module_08_share_save"],"selection_scope":["share_safe_boundary"],"candidate_replaces":["asset.module_08_share_save.boundary_registry.share_boundary.v0_3"],"original_reading_modes":["quick","standard","share_safe"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["boundary_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_08_share_save.boundary.share_boundary","selection_priority":85,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":241,"sentence_count":4,"has_trait_layer":false,"has_score_band_layer":false,"has_coupling_layer":false,"has_facet_layer":true,"has_real_world_layer":true,"has_cost_layer":false,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":false,"template_risk":"v0_5_human_review_candidate","rendered_preview_required":true},"safety