      "access_level": "paid",
      "module_code": "relationships"
    },
    {
      "id": "rel_axis_TF_F_strong",
      "section": "relationships",
      "title": "F 偏好较强：通过感受共鸣与体贴回应建立安全感",
      "desc": "你更容易从情绪、体验和价值一致性出发理解关系，因此很重视被看见和被理解。",
      "bullets": [
        "你会细致感知关系中的温度变化",
        "被理解会显著提高你的投入度",
        "你擅长用体贴维护关系连接"
      ],
      "tips": [
        "别只照顾别人，也把自己的边界说清",
        "把委屈翻译成清楚请求，而不是靠猜测"
      ],
      "tags": [
        "kind:axis",
        "axis:TF:F",
        "state:strong",
        "topic:care"
      ],
      "priority": 94,
