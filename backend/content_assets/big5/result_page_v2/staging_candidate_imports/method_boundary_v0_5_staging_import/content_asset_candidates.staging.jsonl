{"asset_id":"candidate_content_method_boundary_v0_5_11","asset_key":"candidate.method_boundary.organization_use_boundary.v0_5","asset_version":"v0_5","asset_type":"method_boundary","asset_layer":"L0_governance","module_key":"module_10_method_privacy","section_key":"method_privacy","slot_key":"module_10_method_privacy.boundary.non_screening_boundary","copy_role":"user_visible_method_boundary_candidate","reading_mode":["quick","standard","deep"],"title_zh":"组织场景只能用于沟通，不能用于筛选","body_zh":"在组织场景中，大五结果有一个安全用途：帮助成员说明自己如何接收反馈、如何进入任务、在压力下需要什么支持。它不适合承担人事裁决功能。一个人的工作表现来自技能、经验、资源、管理方式和环境，不是由人格倾向单独决定。把测评用于沟通，是帮助人更好合作；把测评用于筛选或排序，会把解释工具变成不公平的裁决工具。\n\n边界：结果不能用于候选人淘汰、员工评级、晋升排序、绩效判断或岗位适配裁决。","short_body_zh":"团队可以用结果讨论协作方式，但不能把它当作录用、淘汰、晋升或评级依据。","cta_zh":"团队使用时，只讨论“怎样合作更顺畅”，不要讨论“谁更适合留下”。","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["boundary_registry"],"target_module":["module_10_method_privacy"],"selection_scope":["organization_use_boundary"],"candidate_replaces":["asset.module_10_method_privacy.boundary_registry.non_screening_boundary.v0_3"],"original_reading_modes":["quick","standard","deep"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["boundary_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_10_method_privacy.boundary.non_screening_boundary","selection_priority":84,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":267,"sentence_count":5,"has_trait_layer":false,"has_score_band_layer":false,"has_coupling_layer":false,"has_facet_layer":false,"has_real_world_layer":true,"has_cost_layer":false,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":