{
  "schema_version": 1,
  "version": "crawler-log-aggregate-dry-run.v1",
  "task": "CRAWLER-LOG-03",
  "runtime": "crawler_log_observe",
  "mode": "synthetic_fixture_aggregate_dry_run",
  "service": "App\\Services\\SeoIntel\\CrawlerLog\\CrawlerLogAggregateDryRun",
  "command": "php artisan seo-intel:crawler-log-observe --fixture --dry-run --no-write --json --limit=20",
  "fixture_path": "backend/tests/Fixtures/SeoIntel/crawler_logs/nginx_access_sample.log",
  "privacy_transform_version": "crawler_log_privacy_transform_v1",
  "target_table": "seo_crawler_logs_daily",
  "target_table_write_attempted": false,
  "target_table_write_committed": false,
  "no_production_log_read": true,
  "no_database_writes": true,
  "no_collector_write": true,
