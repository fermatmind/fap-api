{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fermatmind.com/schemas/iq/iq_scoring.v1.json",
  "title": "FermatMind IQ Scoring Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scale_code",
    "scoring_mode",
    "bank_id",
    "answer_key_version",
    "norm_table_version",
    "scoring_engine_version",
    "items",
    "aggregation",
    "quality_rules"
  ],
  "properties": {
    "schema_version": {
      "const": "iq_scoring.v1"
    },
    "scale_code": {
      "const": "IQ_INTELLIGENCE_QUOTIENT"
    },
    "scoring_mode": {
      "const": "scored"
    },
    "bank_id": {
      "type": "string",
      "minLength": 1
    },
    "answer_key_version": {
      "type": "string",
      "minLength": 1
    },
    "norm_table_version": {
      "type": "string",
      "minLength": 1
    },
    "scoring_engine_version": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "dimension",
          "correct_answer",
          "raw_points"
        ],
        "properties": {
          "item_id": {
            "type": "string",
            "pattern": "^FM-IQ-(VSPR|VSI|NPR)-[A-Z0-9_]+-L[1-5]-[A-Z0-9]{4,6}$"
          },
          "dimension": {
            "type": "string",
            "enum": [
              "VSPR",
              "VSI",
              "NPR"
            ]
          },
          "correct_answer": {
            "type": "string",
            "minLength": 1
          },
          "raw_points": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "aggregation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_score",
        "dimension_scores",
        "iq_estimate",
        "percentile",
        "confidence_interval",
        "result_stability"
      ],
      "properties": {
        "raw_score": {
          "$ref": "#/$defs/calculationRule"
        },
        "dimension_scores": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "VSPR",
            "VSI",
            "NPR"
          ],
          "properties": {
            "VSPR": {
              "$ref": "#/$defs/calculationRule"
            },
            "VSI": {
              "$ref": "#/$defs/calculationRule"
            },
            "NPR": {
              "$ref": "#/$defs/calculationRule"
            }
          }
        },
        "iq_estimate": {
          "$ref": "#/$defs/calculationRule"
        },
        "percentile": {
          "$ref": "#/$defs/calculationRule"
        },
        "confidence_interval": {
          "$ref": "#/$defs/calculationRule"
        },
        "result_stability": {
          "$ref": "#/$defs/calculationRule"
        }
      }
    },
    "quality_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "speeding_seconds_lt",
        "straightlining_run_len_gte",
        "abnormal_quality_policy"
      ],
      "properties": {
        "speeding_seconds_lt": {
          "type": "integer",
          "minimum": 0
        },
        "straightlining_run_len_gte": {
          "type": "integer",
          "minimum": 0
        },
        "abnormal_quality_policy": {
          "type": "string",
          "enum": [
            "allow_with_caution",
            "downgrade_stability",
            "suppress_score"
          ]
        }
      }
    }
  },
  "$defs": {
    "calculationRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_field": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
