{"asset_id":"candidate_content_method_boundary_v0_5_08","asset_key":"candidate.method_boundary.low_quality_show_soften_hide.v0_5","asset_version":"v0_5","asset_type":"result_state","asset_layer":"L0_governance","module_key":"module_10_method_privacy","section_key":"method_privacy","slot_key":"module_10_method_privacy.boundary.low_quality_boundary","copy_role":"user_visible_method_boundary_candidate","reading_mode":["quick","standard","deep"],"title_zh":"作答信号不足时，先降级解释","body_zh":"有些作答会呈现速度过快、选择过于单一、前后不够一致、注意力不足或自我观察不清晰等信号。遇到这种情况，报告应该保留最稳的部分：五维大方向、方法边界和复测建议；应该弱化组合推断、细分判断和长期结论；应该隐藏需要高置信支持的比较与分享内容。这不是惩罚用户，而是保护解释质量。\n\n边界：作答质量不足时，不应输出强画像、细分断言、公开分享摘要或高风险用途建议。","short_body_zh":"低质量不等于用户有问题，只表示这次结果不适合承载太强的解释。","cta_zh":"先把本次结果当草稿。等状态稳定后再复测，再看哪些倾向仍然反复出现。","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["boundary_registry"],"target_module":["module_10_method_privacy"],"selection_scope":["low_quality_degrade_boundary"],"candidate_replaces":["asset.module_10_method_privacy.boundary_registry.low_quality_boundary.v0_3"],"original_reading_modes":["quick","standard","deep"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["boundary_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_10_method_privacy.boundary.low_quality_boundary","selection_priority":87,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":246,"sentence_count":4,"has_trait_layer":false,"has_score_band_layer":false,"has_coupling_layer":true,"has_facet_layer":true,"has_real_world_layer":false,"has_cost_layer":true,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":false,"template_risk":"v0_