{
  "version": "crawler-log-aggregate-observation-design.v1",
  "task": "CRAWLER-LOG-06",
  "design_type": "aggregate_observation_design",
  "purpose": "Define privacy-safe aggregate crawler log observation after the first bounded production canary without expanding reads or adding writes.",
  "no_production_log_read": true,
  "no_canary_execution": true,
  "no_database_write": true,
  "no_scheduler": true,
  "no_issue_queue_write": true,
  "no_url_truth_mutation": true,
  "no_search_channel_queue_enqueue": true,
  "no_search_submission": true,
  "no_external_search_api": true,
  "allowed_inputs": [
    "approved_sanitized_aggregate_dry_run_output",
    "approved_sanitized_aggregate_canary_output"
  ],
  "allowed_future_storage_sources": [
    "seo_crawler_logs_daily"
  ],
  "forbidden_inputs": [
    "raw_production_access_logs",
    "raw_request_rows",
    "raw_ip_addresses",
    "raw_user_agents",
    "raw_request_uris",
    "raw_query_strings",
    "cookies",
    "headers",
    "tokens",
    "emails",
    "order_ids",
    "payment_ids",
    "attempt_ids",
    "provider_payloads",
    "application_debug_logs",
    "business_db_logs",
    "node2_local_db_or_logs",
    "tencent_rds_business_sources",
    "metabase_raw_datasource_mutation"
  ],
  "aggregate_grain": [
    "log_date",
    "host",
    "surface_family",
    "bot_family",
    "bot_variant",
    "bot_verification_state",
    "route_family",
    "page_entity_type",
    "http_status",
    "method_bucket",
    "query_present",
    "query_risk_state",
    "private_path_blocked",
    "source_log_family",
    "privacy_transform_version"
  ],
  "aggregate_measures": [
    "hit_count",
    "first_seen_at",
    "last_seen_at"
  ],
  "allowed_optional_safe_path_fields": [
    "canonical_path_when_mapped_to_safe_public_url_truth",
    "path_hash_for_unknown_private_blocked_or_unsafe_paths"
  ],
  "forbidden_persistent_fields": [
    "ip_address",
    "remote_addr",
    "raw_user_agent",
    "raw_request_uri",
    "raw_query_string",
    "cookie",
    "headers",
    "authorization",
    "session_id",
    "token",
    "api_key",
    "email",
    "order_no",
    "attempt_id",
    "payment_id",
    "provider_event_id",
    "raw_payload",
    "raw_log_line",
    "event_payload",
    "metadata_json",
    "attributes_json"
  ],
  "safe_dashboard_metrics": [
    "total_aggregate_hits",
    "bot_family_breakdown",
    "bot_verification_state_breakdown",
    "surface_family_breakdown",
    "route_family_breakdown",
    "http_status_breakdown",
    "method_bucket_breakdown",
    "query_risk_state_breakdown",
    "private_path_blocked_count",
    "unknown_public_path_count",
    "static_asset_hit_count",
    "safe_public_canonical_path_count",
    "non_bot_count",
    "unknown_bot_count",
    "latest_approved_canary_timestamp"
  ],
  "warning_when_nonzero": [
    "private_path_blocked_count",
    "sensitive_key_present_count",
    "unknown_public_path_count",
    "api_surface_count",
    "ops_surface_count",
    "raw_persistence_attempted_count",
    "write_attempted_count",
    "search_submission_attempted_count",
    "scheduler_enabled_count"
  ],
  "authority_boundary": {
    "crawler_logs_are_url_truth": false,
    "crawler_logs_create_seo_urls": false,
    "crawler_logs_update_seo_urls": false,
    "crawler_logs_decide_canonical": false,
    "crawler_logs_decide_indexability": false,
    "crawler_logs_override_cms_backend_truth": false,
    "crawler_logs_create_search_channel_queue_items": false,
    "crawler_logs_approve_search_channel_queue_items": false,
    "crawler_logs_retry_search_channel_queue_items": false,
    "crawler_logs_submit_urls": false,
    "crawler_logs_auto_write_issue_queue": false
  },
  "future_storage_requirements": {
    "connection": "seo_intel",
    "preferred_table": "seo_crawler_logs_daily",
    "raw_persistence_allowed": false,
    "write_gate_disabled_by_default": true,
    "dry_run_required_before_write": true,
    "scheduler_requires_separate_readiness_task": true,
    "idempotency_required": true
  },
  "reporting_boundary": {
    "allow_aggregate_counts": true,
    "allow_safe_dimensions": true,
    "allow_safe_canonical_path_only_when_url_truth_mapped": true,
    "allow_raw_private_or_unknown_paths": false,
    "allow_raw_payloads": false
  },
  "next_tasks": [
    "CRAWLER-LOG-07",
    "CRAWLER-LOG-08",
    "CRAWLER-LOG-09",
    "CRAWLER-LOG-10",
    "CRAWLER-LOG-11"
  ],
  "final_decision": "crawler_log_aggregate_observation_design_ready_for_storage_contract",
  "next_task": "CRAWLER-LOG-07"
}
