        "zh-CN": {
            "schema": "fap.questions.v1",
            "locale": "zh-CN",
            "items": [
                {
                    "question_id": "1",
                    "order": 1,
                    "direction": 1,
                    "text": "近期我觉得心情郁闷、情绪低沉、不开心"
                },
                {
                    "question_id": "2",
                    "order": 2,
                    "direction": -1,
                    "text": "我觉得一天之中，在早晨的时候我的心情是最好的"
                },
                {
                    "question_id": "3",
                    "order": 3,
                    "direction": 1,
                    "text": "我会一阵阵哭出来或感觉很想哭"
                },
                {
                    "question_id": "4",
                    "order": 4,
                    "direction": 1,
                    "text": "我晚上睡眠不好"
                },
                {
                    "question_id": "5",
                    "order": 5,
                    "direction": -1,
                    "text": "我最近食量比较平均，吃的和平时一样多"
                },
                {
                    "question_id": "6",
                    "order": 6,
                    "direction": -1,
                    "text": "我与异性亲密接触时和以往一样愉快"
                },
                {
                    "question_id": "7",
                    "order": 7,
                    "direction": 1,
                    "text": "我感觉到体重有减轻"
                },
                {
                    "question_id": "8",
                    "order": 8,
                    "direction": 1,
                    "text": "我有便秘的苦恼"
                },
                {
                    "question_id": "9",
                    "order": 9,
                    "direction": 1,
                    "text": "我感觉到心跳比平常快"
                },
                {
                    "question_id": "10",
                    "order": 10,
                    "direction": 1,
                    "text": "我无缘无故地感到疲乏"
                },
                {
                    "question_id": "11",
                    "order": 11,
                    "direction": -1,
                    "text": "我的头脑跟平常一样清楚"
                },
                {
                    "question_id": "12",
                    "order": 12,
                    "direction": -1,
                    "text": "我做过去经常做的事情，不觉得有什么困难"
                },
                {
                    "question_id": "13",
                    "order": 13,
                    "direction": 1,
                    "text": "我觉得不安，而且难以保持平静"
                },
                {
                    "question_id": "14",
                    "order": 14,
                    "direction": -1,
                    "text": "我对未来抱有希望"
                },
                {
                    "question_id": "15",
                    "order": 15,
                    "direction": 1,
                    "text": "我比平常容易生气激动"
                },
                {
                    "question_id": "16",
                    "order": 16,
                    "direction": -1,
                    "text": "我发现做出决定是容易的事"
                },
                {
                    "question_id": "17",
                    "order": 17,
                    "direction": -1,
                    "text": "我觉得自己是个有用的人，有人需要我"
                },
                {
                    "question_id": "18",
                    "order": 18,
                    "direction": -1,
                    "text": "我的生活过得很有意思"
                },
                {
                    "question_id": "19",
                    "order": 19,
                    "direction": 1,
                    "text": "我认为如果我死了，别人会生活得好些"
                },
                {
                    "question_id": "20",
                    "order": 20,
                    "direction": -1,
                    "text": "对平常感兴趣的事情我仍然感兴趣"
                }
            ]
        },
        "en": {
