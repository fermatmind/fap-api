    "entries": [
        {
            "day": 1,
            "phase": "core_motivation_observation",
            "title": "Day 1｜先抓触发点",
            "prompt": "今天只记录一个让你明显收缩、推进、解释、讨好、控制或退开的场景。不要急着分析类型，先看自动反应是怎样启动的。",
            "example": "例如：会议里有人否定方案，你是先想纠正、先想证明、先想确认风险，还是先想把场面压平？",
            "user_input_schema": {
                "type": "object",
                "fields": {
                    "trigger_scene": {
                        "type": "enum",
                        "options": ["work", "relationship", "pressure", "alone", "other"]
                    },
                    "trigger_description": {
                        "type": "text",
                        "max_length": 280
                    },
                    "automatic_reaction": {
                        "type": "enum",
                        "options": ["push", "withdraw", "please", "control", "explain", "freeze", "reframe", "other"]
                    }
                }
            },
            "analytics_event_key": "enneagram_observation_day1_started",
            "suggested_next_action": "observe_7_days",
            "boundary_copy": "这一步只记录现实证据，不急着把自己定成某个号码。",
            "content_maturity": "p0_ready",
            "evidence_level": "descriptive"
        },
        {
            "day": 2,
            "phase": "core_motivation_observation",
            "title": "Day 2｜看你真正怕失去什么",
            "prompt": "回看今天一个明显不舒服的瞬间：你最怕失去的是正确感、认可、关系位置、安全、边界、自由、真实，还是平静？",
            "example": "例如：如果一件事做得不漂亮，你不舒服是因为它不对、它不成、它不稳，还是它让你失去空间？",
            "user_input_schema": {
                "type": "object",
                "fields": {
                    "core_fear_selection": {
                        "type": "enum",
                        "options": ["correctness", "recognition", "being_needed", "safety", "boundary", "freedom", "authenticity", "harmony", "other"]
                    },
                    "evidence_sentence": {
                        "type": "text",
                        "max_length": 280
                    }
                }
            },
            "analytics_event_key": "enneagram_observation_day2_pattern_logged",
            "suggested_next_action": "observe_7_days",
            "boundary_copy": "只记录最像你的动力，不必追求一次就找到最终答案。",
            "content_maturity": "p0_ready",
            "evidence_level": "descriptive"
        },
        {
