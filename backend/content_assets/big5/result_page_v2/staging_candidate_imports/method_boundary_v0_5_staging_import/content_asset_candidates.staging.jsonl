{"asset_id":"candidate_content_method_boundary_v0_5_13","asset_key":"candidate.method_boundary.retest_frequency_and_trend.v0_5","asset_version":"v0_5","asset_type":"method_boundary","asset_layer":"L0_governance","module_key":"module_10_method_privacy","section_key":"method_privacy","slot_key":"module_10_method_privacy.method.retest_method","copy_role":"user_visible_method_boundary_candidate","reading_mode":["standard","deep"],"title_zh":"复测看趋势，不刷结果","body_zh":"复测的价值，不是追求一个更好看的结果，也不是证明自己彻底变成另一种人。更有意义的做法是：间隔一段时间，在相对稳定的状态下重新作答，然后把两次结果和真实行为记录放在一起看。哪些倾向反复出现，可能更稳定；哪些变化只在某段压力或环境中出现，就更适合当作阶段性线索。\n\n边界：频繁复测容易放大当下情绪和作答习惯，不适合用来证明人格变好或变差。","short_body_zh":"人格特质有稳定性，但生活阶段、压力和自我管理方式会影响具体表现。","cta_zh":"复测前先记录三件事：最近的压力来源、协作方式变化、一个你想验证的行为倾向。","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["method_registry"],"target_module":["module_10_method_privacy"],"selection_scope":["retest_method_boundary"],"candidate_replaces":["asset.module_10_method_privacy.method_registry.retest_method.v0_3"],"original_reading_modes":["standard","deep"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["method_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_10_method_privacy.method.retest_method","selection_priority":82,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":241,"sentence_count":4,"has_trait_layer":false,"has_score_band_layer":false,"has_coupling_layer":false,"has_facet_layer":false,"has_real_world_layer":false,"has_cost_layer":false,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":false,"template_risk":"v0_5_human_review_candidate","rendered_preview_required":