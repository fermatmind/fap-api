{"asset_id":"candidate_content_method_boundary_v0_5_14","asset_key":"candidate.method_boundary.deep_reading_evidence_strength.v0_5","asset_version":"v0_5","asset_type":"method_boundary","asset_layer":"L0_governance","module_key":"module_10_method_privacy","section_key":"method_privacy","slot_key":"module_10_method_privacy.method.review_method","copy_role":"user_visible_method_boundary_candidate","reading_mode":["deep"],"title_zh":"深度阅读要区分证据强弱","body_zh":"深度阅读不是把结论说得更满，而是把证据分层。五个大维度通常更适合做结构判断；细分面向更适合解释差异；双维组合能提示张力和资源；场景建议则需要回到用户自己的生活中检验。好的深度报告不应该让你更依赖一个标签，而应该让你更清楚：哪些地方已经足够稳定，哪些地方还需要观察。\n\n边界：篇幅增加不代表确定性增加。任何深度解释都必须保留方法边界、质量边界和隐私边界。","short_body_zh":"报告越完整，越需要说明哪些是稳定结构，哪些只是待观察线索。","cta_zh":"阅读深度内容时，把句子分成三类：已验证、待观察、暂不符合。只把已验证部分带入行动。","applies_to":{"scale_code":["BIG5_OCEAN"],"candidate_stage":["method_boundary_v0_5_normalized"],"target_registry_key":["method_registry"],"target_module":["module_10_method_privacy"],"selection_scope":["deep_reading_evidence_strength"],"candidate_replaces":["asset.module_10_method_privacy.method_registry.review_method.v0_3"],"original_reading_modes":["deep"]},"avoid_when":[{"field":"runtime_use","operator":"not_equals","value":"staging_only","action":"block_runtime_use"},{"field":"production_use_allowed","operator":"not_equals","value":false,"action":"block_production_use"}],"can_combine_with":["method_registry"],"cannot_combine_with":["runtime_use","production_use","frontend_copy"],"dedupe_group":"method_boundary_v0_5.module_10_method_privacy.method.review_method","selection_priority":81,"selection_specificity":10,"fallback_allowed":false,"render_surface":[],"body_quality":{"body_chars":252,"sentence_count":5,"has_trait_layer":true,"has_score_band_layer":false,"has_coupling_layer":true,"has_facet_layer":true,"has_real_world_layer":true,"has_cost_layer":false,"has_strength_layer":false,"has_action_layer":true,"has_boundary_layer":true,"has_editorial_leakage":false,"template_risk":"v0_5_human_review_candidate","rendered_preview_required":tru