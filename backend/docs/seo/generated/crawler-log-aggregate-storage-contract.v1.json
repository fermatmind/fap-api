{
  "version": "crawler-log-aggregate-storage-contract.v1",
  "task": "CRAWLER-LOG-07",
  "contract_type": "aggregate_storage_contract",
  "target_connection": "seo_intel",
  "target_table": "seo_crawler_log_daily_aggregates",
  "legacy_table": "seo_crawler_logs_daily",
  "legacy_table_v1_write_approved": false,
