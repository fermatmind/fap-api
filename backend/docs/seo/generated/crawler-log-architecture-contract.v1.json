    "--fixture",
    "--dry-run",
    "--no-write",
    "--json",
    "--limit"
  ],
  "future_forbidden_flags": [
    "--production",
    "--tail",
    "--schedule",
    "--write"
  ],
  "required_dry_run_output_fields": [
    "dry_run",
    "writes_attempted",
    "writes_committed",
    "production_log_read_attempted",
    "external_calls_attempted",
    "search_submission_attempted",
